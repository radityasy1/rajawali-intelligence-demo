# Google Gemini API Key (required for chat functionality)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here

# Demo API Key (optional - for shared demo access)
# Share this with reviewers who don't have their own API key
GEMINI_API_KEY_DEMO=

# Database path (default: ./data/demo.db)
# DB_PATH=./data/demo.db

# LanceDB path (default: ./data/lancedb)
# LANCEDB_PATH=./data/lancedb

# Environment (development/production)
ENV=development

# Logging level
LOG_LEVEL=INFO